# Spotify API Configuration
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# NextAuth Configuration
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
# Development: http://localhost:3000
# Production: https://your-production-domain.com (uten trailing slash)
# Må matche redirect URI i Spotify Developer Dashboard
NEXTAUTH_URL=http://localhost:3000

# Firebase Configuration (same project as Flutter djsports app)
# Find these in Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Optional: Environment
NODE_ENV=development
